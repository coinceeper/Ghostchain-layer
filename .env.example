# ─────────────────────────────────────
# GhostChain Protocol - Environment Configuration
# ─────────────────────────────────────
# Copy this to .env and fill in your values.
# WARNING: Never commit .env files to version control!
#
# Chain-Agnostic RPC Management:
#   The Relayer auto-discovers supported chains from RPC_<SHORT_NAME> env vars.
#   Add a new chain by simply adding its RPC URL here — no code changes needed.
#   Short names match the CHAIN_METADATA in sdk/src/chains.ts (lowercase, hyphen to underscore).

# ───── Deployment ─────
PRIVATE_KEY=your_deployer_private_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key

# ───── Mainnet RPC Endpoints ─────
# EVM chains supported by GhostChain. Uncomment and set RPC URLs for chains you want to support.
RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_POLYGON=https://polygon-rpc.com
RPC_OPTIMISM=https://mainnet.optimism.io
RPC_BASE=https://mainnet.base.org
RPC_BSC=https://bsc-dataseed.binance.org/
RPC_AVALANCHE=https://api.avax.network/ext/bc/C/rpc
RPC_FANTOM=https://rpc.ftm.tools/
RPC_LINEA=https://rpc.linea.build
#RPC_ZKSYNC=https://mainnet.era.zksync.io
#RPC_SCROLL=https://rpc.scroll.io
#RPC_MANTLE=https://rpc.mantle.xyz

# ───── Testnet RPC Endpoints ─────
RPC_SEPOLIA=https://rpc.sepolia.org
RPC_ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc
RPC_POLYGON_AMOY=https://rpc-amoy.polygon.technology
RPC_OPTIMISM_SEPOLIA=https://sepolia.optimism.io
RPC_BASE_SEPOLIA=https://sepolia.base.org
RPC_BSC_TESTNET=https://data-seed-prebsc-1-s1.binance.org:8545/

# ───── Contract Addresses ─────
# Use the format <SHORTNAME_UPPERCASE>_FACTORY and <SHORTNAME_UPPERCASE>_VERIFIER
# The Relayer auto-discovers these through the chain registry.
ARBITRUM_FACTORY=0x...
ARBITRUM_VERIFIER=0x...
POLYGON_FACTORY=0x...
POLYGON_VERIFIER=0x...
OPTIMISM_FACTORY=0x...
OPTIMISM_VERIFIER=0x...
BASE_FACTORY=0x...
BASE_VERIFIER=0x...
ETHEREUM_FACTORY=0x...
ETHEREUM_VERIFIER=0x...
BSC_FACTORY=0x...
BSC_VERIFIER=0x...
AVALANCHE_FACTORY=0x...
AVALANCHE_VERIFIER=0x...
FANTOM_FACTORY=0x...
FANTOM_VERIFIER=0x...
LINEA_FACTORY=0x...
LINEA_VERIFIER=0x...

# ───── USDT Addresses (for reference) ─────
# Canonical USDT addresses live in sdk/src/chains.ts (USDT_ADDRESSES).
# Override per-chain here if needed:
#ARBITRUM_USDT=0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9
#POLYGON_USDT=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
#OPTIMISM_USDT=0x94b008aA00579c1307B0EF2c499aD98a8ce58e58
#BASE_USDT=0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2
#BSC_USDT=0x55d398326f99059fF775485246999027B3197955

# ───── Solver Configuration ─────
SOLVER_ID=ghostchain-solver-1
SOLVER_PRIVATE_KEY=your_solver_wallet_private_key
MIN_FEE_BPS=30
MAX_FILL_USD=10000
API_PORT=3000
LOG_LEVEL=info

# ───── ZK Prover Configuration ─────
ZK_PROVER_ENDPOINT=http://localhost:8080
ZKEY_PATH=./zk/build/circuit.zkey
GHOST_TRANSFER_WASM_PATH=./zk/build/ghostTransfer.wasm
VERIFICATION_KEY_PATH=./zk/build/verification_key.json
USE_FULL_PROVING=false

# ───── Key Manager Configuration ─────
# Options: 'local' (development), 'aws-kms' (production)
# For AWS KMS, also set AWS_KMS_KEY_ID and AWS_REGION
KEY_MANAGER_TYPE=local
#AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/abc123
#AWS_REGION=us-east-1
