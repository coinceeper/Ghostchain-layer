{
  "detectors_to_exclude": [
    "solc-version",
    "naming-convention",
    "pragma",
    "too-many-digits"
  ],
  "exclude_informational": true,
  "exclude_low": false,
  "exclude_medium": false,
  "exclude_high": false,
  "filter_paths": "(lib/|test/|script/|interfaces/)",
  "solc_remaps": [
    "forge-std/=lib/forge-std/src/"
  ]
}
