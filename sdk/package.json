{
  "name": "@ghostchain/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "GhostChain SDK - Multi-chain client library for censorship-resistant private USDT transfers with ZK proofs and intent-based routing",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./*": "./dist/*"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "viem": "^2.9.0",
    "@noble/curves": "^1.3.0",
    "@noble/hashes": "^1.3.0",
    "ethers": "^6.11.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.3.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
