{
  "name": "ghostchain-sdk",
  "version": "0.1.0",
  "description": "GhostChain SDK - Multi-chain client library for censorship-resistant private USDT transfers with ZK proofs and intent-based routing",
  "keywords": [
    "privacy",
    "zero-knowledge",
    "zk-snarks",
    "stealth-addresses",
    "erc-5564",
    "cross-chain",
    "stablecoin",
    "ghostchain"
  ],
  "homepage": "https://github.com/coinceeper/Ghostchain-layer#readme",
  "bugs": {
    "url": "https://github.com/coinceeper/Ghostchain-layer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coinceeper/Ghostchain-layer.git",
    "directory": "sdk"
  },
  "license": "MIT",
  "author": "Mohammad Nazarnejad",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./*": "./dist/*"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/curves": "^1.3.0",
    "@noble/hashes": "^1.3.0",
    "@scure/bip32": "^1.3.0",
    "poseidon-lite": "^0.3.0",
    "viem": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
