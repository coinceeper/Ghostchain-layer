# Example testnet environment variables for GhostChain deployment
# Copy this file to .env.testnet and fill in the missing values.

# RPC endpoints accepted by forge aliases in contracts/package.json
RPC_URL=arbitrum_sepolia
# or: base_sepolia

# Deployer wallet private key for testnet deployment
PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY

# Optional recommended production variables for testnet tests
REGISTRY_OWNER=0xYOUR_MULTISIG_OR_TEST_WALLET
VERIFIER_ADDRESS=0xYOUR_PREDEPLOYED_VERIFIER_ADDRESS

# Optional local demo frontend values
FACTORY_ADDRESS=0xYOUR_DEPLOYED_FACTORY_ADDRESS
SWAP_ID=0xYOUR_TESTNET_SWAP_ID
