{
  "name": "@ghostchain/relayer",
  "version": "0.1.0",
  "private": true,
  "description": "GhostChain Solver/Relayer - Off-chain service for intent-based cross-chain routing. Monitors intents, manages liquidity, and fulfills swaps across multiple chains.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "start": "node dist/index.js",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --onSuccess \"node dist/index.js\"",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "viem": "^2.9.0",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "@ghostchain/sdk": "^0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.3.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17"
  }
}
