# GhostChain npm registry configuration
# This file enables publishing @ghostchain packages to npm.
# Set NPM_TOKEN in your environment or .npmrc to publish.
#
# Usage:
#   export NPM_TOKEN=npm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   npm publish --access public
#
# For local development, no token is needed — packages resolve
# via npm workspaces within the monorepo.

@ghostchain:registry=https://registry.npmjs.org/
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
